# Copy this file to ".env" and fill in your real keys.
# The .env file is gitignored — never commit your real keys.

BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# true  = Bybit testnet (paper/virtual money) — SAFE default
# false = Bybit mainnet (REAL money)
BYBIT_TESTNET=true
